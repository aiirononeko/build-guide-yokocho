---
import type { CollectionEntry } from "astro:content";
import type { Locale } from "../i18n/ui";
import { useTranslations, getLocalePath } from "../i18n/utils";

type GuideData = CollectionEntry<"guides">["data"] & { id: string };

type Props = {
  guide: GuideData;
  index: number;
  lang?: Locale;
  highlight?: boolean;
};

const { guide, index, lang = "ja", highlight = false } = Astro.props;
const t = useTranslations(lang);
const indexStr = String(index).padStart(3, "0");

const description =
  lang === "en" && guide.descriptionEn ? guide.descriptionEn : guide.description;
const tags = lang === "en" && guide.tagsEn ? guide.tagsEn : guide.tags;
const sharePath = getLocalePath(lang, `/share/${guide.id}`);
const shareTitle = guide.name;
const shareLabel = t("card.share");
const copiedLabel = t("card.copied");
---

<article
  class="card"
  data-card
  data-id={guide.id}
  data-name={guide.name.toLowerCase()}
  data-designer={guide.designer.toLowerCase()}
  data-tags={tags.join(",")}
  data-highlight={highlight ? "true" : undefined}
>
  <div class="card-header">
    <span class="card-index">N°{indexStr}</span>
    <span class="card-divider"></span>
    <button
      type="button"
      class="card-share"
      data-share-path={sharePath}
      data-share-title={shareTitle}
      data-copied-label={copiedLabel}
      aria-label={shareLabel}
      title={shareLabel}
    >
      <svg
        class="card-share-icon"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M8 10.5V2" />
        <path d="M5 5l3-3 3 3" />
        <path d="M3 8.5v4.5a1.5 1.5 0 0 0 1.5 1.5h7a1.5 1.5 0 0 0 1.5-1.5V8.5" />
      </svg>
    </button>
    <span class="card-dot" aria-hidden="true">●</span>
  </div>

  <div class="card-body">
    <h3 class="card-title">{guide.name}</h3>
    <p class="card-designer">
      {t("card.by")} <span>{guide.designer}</span>
    </p>
    <p class="card-desc">{description}</p>
  </div>

  <div class="card-tags">
    {tags.map((tag) => <span class="card-tag">#{tag}</span>)}
  </div>

  <div class="card-links">
    <a
      href={guide.url}
      target="_blank"
      rel="noopener noreferrer"
      class="card-link primary"
    >
      <span>{t("card.buildGuide")}</span>
      <span class="arrow">→</span>
    </a>
    {
      guide.shopLinks.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          class="card-link"
        >
          <span>{s.name}</span>
          <span class="arrow">→</span>
        </a>
      ))
    }
  </div>
</article>

<style>
  .card {
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    transition: background-color 0.2s ease;
    min-height: 360px;
  }

  .card:hover {
    background: var(--bg-elev);
  }

  .card:hover .card-dot {
    color: var(--accent);
  }

  .card.is-highlight {
    box-shadow: inset 0 0 0 2px var(--accent);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    text-transform: uppercase;
  }

  .card-index {
    font-weight: 600;
  }

  .card-divider {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .card-dot {
    color: var(--text-mute);
    font-size: 8px;
    transition: color 0.2s ease;
  }

  .card-share {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    color: var(--text-mute);
    transition: color 0.15s ease;
  }

  .card-share:hover {
    color: var(--accent);
  }

  .card-share-icon {
    width: 14px;
    height: 14px;
  }

  .card-share[data-copied="true"]::after {
    content: attr(data-copied-label);
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 8px;
    background: var(--text);
    color: var(--bg);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: none;
    white-space: nowrap;
    pointer-events: none;
    z-index: 5;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .card-designer {
    font-size: 13px;
    color: var(--text-soft);
    letter-spacing: 0.01em;
  }

  .card-designer span {
    color: var(--accent);
    font-weight: 500;
  }

  .card-desc {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--text-soft);
    margin-top: 6px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
  }

  .card-tag {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--text-mute);
    letter-spacing: 0.02em;
  }

  .card-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 18px;
    border-top: 1px dashed var(--border);
  }

  .card-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--text);
    padding: 8px 0;
    transition: color 0.15s ease;
  }

  .card-link.primary {
    font-weight: 600;
  }

  .card-link + .card-link {
    border-top: 1px dashed var(--border);
  }

  .card-link:hover {
    color: var(--accent);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .card-link:hover .arrow {
    transform: translateX(4px);
  }
</style>
